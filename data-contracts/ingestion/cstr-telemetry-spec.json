{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CSTR_Sanitized_Telemetry_Contract",
  "description": "Flattened telemetry payload for Spanner ingestion. Enforces strict schema versioning for edge evolution.",
  "type": "object",
  "properties": {
    "event_metadata": {
      "type": "object",
      "properties": {
        "schema_version": { 
          "type": "string", 
          "enum": ["1.0.0", "1.1.0"],
          "description": "Critical for DLQ routing. 1.0.0 = Base Thermal/Pressure. 1.1.0 = Adds pH and Dissolved Oxygen."
        },
        "event_id": { "type": "string", "format": "uuid" },
        "timestamp": { "type": "string", "format": "date-time" },
        "facility_id": { "type": "string", "enum": ["EU-01", "EU-02", "REDACTED"] },
        "machine_id": { "type": "string", "description": "Format: CSTR-[ID]" }
      },
      "required": ["schema_version", "event_id", "timestamp", "facility_id", "machine_id"]
    },
    "telemetry": {
      "type": "object",
      "properties": {
        "sensor_type": { 
          "type": "string", 
          "enum": ["thermal", "pressure", "agitation", "ph", "dissolved_oxygen"] 
        },
        "reading_value": { "type": "number" },
        "unit_of_measure": { 
          "type": "string", 
          "enum": ["C", "PSI", "RPM", "PH", "MG_L"] 
        },
        "variance_band": { 
          "type": "string", 
          "description": "Tolerance deviation for [REDACTED_API_TARGET] synthesis." 
        }
      },
      "required": ["sensor_type", "reading_value", "unit_of_measure"]
    }
  },
  "required": ["event_metadata", "telemetry"]
}